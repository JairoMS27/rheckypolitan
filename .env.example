# Copy to .env and fill in real values. Never commit .env.

# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public (browser) — publishable key only, never the service role
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional Vite aliases (legacy / dual-stack)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Resend (transactional + newsletter)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Supabase Auth → Send Email Hook (Standard Webhooks)
# Dashboard: Authentication → Hooks → Send Email → HTTPS
# Endpoint: https://YOUR_DOMAIN/email/auth/webhook
# Paste the generated secret here (format: v1,whsec_...)
SUPABASE_AUTH_HOOK_SECRET=

# Public site origin (emails, unsubscribe links)
SITE_URL=https://rheckypolitan.es

# Optional: protect cron/background email workers
CRON_SECRET=
